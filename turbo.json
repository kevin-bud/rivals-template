{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["BLOG_PORT", "PRODUCT_PORT", "PRODUCT_INSPECTOR_PORT", "PRODUCT_URL"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".astro/**"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "deploy": {
      "dependsOn": ["build"],
      "cache": false
    }
  }
}
